#!/bin/sh
# Post-install glibc-libs: multiarch symlinks for libstdc++, libgcc_s and libtirpc
ARCH=$(uname -m)
[ "$ARCH" = "x86_64" ] && DIR="x86_64-linux-gnu" || DIR="aarch64-linux-gnu"
mkdir -p "/usr/lib/$DIR"
ln -sf /usr/lib/glibc/lib/libstdc++.so.6 "/usr/lib/$DIR/libstdc++.so.6"
ln -sf /usr/lib/glibc/lib/libgcc_s.so.1  "/usr/lib/$DIR/libgcc_s.so.1"
ln -sf /usr/lib/glibc/lib/libtirpc.so.3  "/usr/lib/$DIR/libtirpc.so.3"
/usr/lib/glibc/sbin/ldconfig 2>/dev/null || true
