#!/bin/sh
# Pre-deinstall glibc-libs: remove multiarch libstdc++, libgcc_s and libtirpc symlinks
ARCH=$(uname -m)
[ "$ARCH" = "x86_64" ] && DIR="x86_64-linux-gnu" || DIR="aarch64-linux-gnu"
rm -f "/usr/lib/$DIR/libstdc++.so.6" "/usr/lib/$DIR/libgcc_s.so.1" "/usr/lib/$DIR/libtirpc.so.3"
/usr/lib/glibc/sbin/ldconfig 2>/dev/null || true
